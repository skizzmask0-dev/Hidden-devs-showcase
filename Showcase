step15_spawnCar = function()
	showArrow(UDim2.new(0.58, 0, 0.82, 0), 180, false)
	NotifModule.NotifyTutorial("🚗 Spawn your Car!")

	local spawned = false
	local SpawnJeepEvt = Remotes:FindFirstChild("SpawnJeep")
	local evtConn = nil

	if SpawnJeepEvt then
		evtConn = SpawnJeepEvt.OnClientEvent:Connect(function()
			spawned = true
		end)
	end

	local pollConn = RunService.Heartbeat:Connect(function()
		if spawned then return end
		for _, obj in ipairs(workspace:GetDescendants()) do
			if (obj:IsA("VehicleSeat") or obj:IsA("Seat")) and obj.Occupant and obj.Occupant.Parent == character then
				spawned = true
			end
		end
	end)

	local carWatch = workspace.ChildAdded:Connect(function(child)
		if child.Name:lower():find("jeep") or child.Name:lower():find("car") then
			task.wait(0.5)
			spawned = true
		end
	end)

	while not spawned do task.wait(0.2) end

	if evtConn then evtConn:Disconnect() end
	pollConn:Disconnect()
	carWatch:Disconnect()

	hideArrow(); NotifModule.ClearTutorial()
	step16_driveToNPC()
end

step16_driveToNPC = function()
	NotifModule.NotifyTutorial("🚗 Drive to the tracked NPC!")

	local function findTrackedNPC()
		local marker = PlayerGui:FindFirstChild("TrackMarker", true)
		if marker then
			local bb = marker:IsA("BillboardGui") and marker or marker.Parent
			if bb and bb:IsA("BillboardGui") and bb.Adornee then
				local model = bb.Adornee.Parent
				if model then
					local h = model:FindFirstChild("HumanoidRootPart")
					if h then return h end
				end
			end
		end
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj.Name == "HumanoidRootPart" and obj.Parent:FindFirstChildOfClass("Humanoid") then
				local isPlayer = false
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Character == obj.Parent then isPlayer = true; break end
				end
				if not isPlayer then return obj end
			end
		end
		return nil
	end

	local npcHRP, attempts = nil, 0
	while not npcHRP and attempts < 20 do
		npcHRP = findTrackedNPC()
		if not npcHRP then task.wait(0.5); attempts += 1 end
	end

	if not npcHRP then step17_openSell(); return end

	createBeam(npcHRP)
	waitUntilClose(npcHRP, 12)
	removeBeam(); NotifModule.ClearTutorial()
	step17_openSell()
end

step17_openSell = function()
	NotifModule.NotifyTutorial("🤝 Talk to the NPC to Sell!")

	local opened = false

	local function checkSellUI(sg)
		if sg.Name == "SellUI" and sg:IsA("ScreenGui") then
			sg:GetPropertyChangedSignal("Enabled"):Connect(function()
				if sg.Enabled then opened = true end
			end)
			if sg.Enabled then opened = true end
		end
	end

	for _, sg in ipairs(PlayerGui:GetChildren()) do checkSellUI(sg) end
	local ac = PlayerGui.ChildAdded:Connect(checkSellUI)
	while not opened do task.wait(0.2) end
	ac:Disconnect()

	NotifModule.ClearTutorial()
	step18_sellCandy()
end

step18_sellCandy = function()
	NotifModule.NotifyTutorial("💰 Sell your candy!")

	local sold = false
	local SellUI = PlayerGui:FindFirstChild("SellUI")
	local honorVal = dataFolder:FindFirstChild("Honor")

	if SellUI then
		local conn = SellUI:GetPropertyChangedSignal("Enabled"):Connect(function()
			if not SellUI.Enabled then sold = true end
		end)
		local hConn = nil
		if honorVal then
			local startH = honorVal.Value
			hConn = honorVal:GetPropertyChangedSignal("Value"):Connect(function()
				if honorVal.Value > startH then sold = true end
			end)
		end
		while not sold do task.wait(0.2) end
		conn:Disconnect()
		if hConn then hConn:Disconnect() end
	else
		task.wait(10)
	end

	task.wait(1)
	completeTutorial()
end

